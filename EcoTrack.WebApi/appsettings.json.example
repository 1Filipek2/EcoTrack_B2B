  "Ai": {
    "Provider": "Ollama",
    "Model": "llama3.2"
  },
  "OpenAI": {
    "ApiKey": ""
  },
  "AzureOpenAI": {
    "Endpoint": "",
    "ApiKey": "",
    "DeploymentName": ""
  },
  "Ollama": {
