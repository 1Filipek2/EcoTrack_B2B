{
  "ConnectionStrings": {
    "EcoTrackDatabase": "Host=YOUR_HOST;Port=5432;Database=YOUR_DB;Username=YOUR_USER;Password=YOUR_PASSWORD;SslMode=Require"
  },
  "JwtSettings": {
    "SecretKey": "YOUR_SECRET_KEY",
    "Issuer": "EcoTrackAPI",
    "Audience": "EcoTrackClient",
    "ExpirationHours": 24
  },
  "Ai": {
    "Provider": "Ollama",
    "Model": "llama3.2"
  },
  "OpenAI": {
    "ApiKey": ""
  },
  "AzureOpenAI": {
    "Endpoint": "",
    "ApiKey": "",
    "DeploymentName": ""
  },
  "Ollama": {
    "BaseUrl": "http://localhost:11434",
    "Model": "llama3.2"
  },
  "SendGrid": {
    "ApiKey": "YOUR_SENDGRID_API_KEY",
    "FromEmail": "ecotrack.noreply@gmail.com",
    "FromName": "EcoTrack"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
